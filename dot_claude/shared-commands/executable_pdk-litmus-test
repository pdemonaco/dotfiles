#!/bin/bash
set -e

SCRIPT_NAME=$(basename "${0}")

INVENTORY_FILE="spec/fixtures/litmus_inventory.yaml"

usage() {
    cat <<EOF
Usage: ${SCRIPT_NAME} [OPTIONS] [test_file_path]

Run Puppet Litmus acceptance tests against Docker hosts defined in the
litmus inventory file.

Options:
  -h, --help       Show this help message and exit
  -l, --list       List Docker hosts from the inventory file and their state
  -a, --all        Run all acceptance tests in parallel via litmus:acceptance:parallel

Arguments:
  test_file_path   Path to the RSpec test file to run (required unless -l or -a is used)

Examples:
  ${SCRIPT_NAME} spec/acceptance/my_test_spec.rb
  ${SCRIPT_NAME} --list
  ${SCRIPT_NAME} --all
EOF
}

list_hosts() {
    if [ ! -f "$INVENTORY_FILE" ]; then
        echo "Error: Inventory file not found: ${INVENTORY_FILE}"
        exit 1
    fi

    echo "Docker hosts in ${INVENTORY_FILE}:"
    echo "---"
    HOSTS=$(yq '(.groups[] | .targets[] | .alias)' "$INVENTORY_FILE")
    for H in $HOSTS; do
        STATE=$(docker inspect --format '{{.State.Status}}' "$H" 2>/dev/null || echo "not found")
        printf "%-40s %s\n" "$H" "$STATE"
    done
}

run_all() {
    echo "Running all acceptance tests in parallel..."
    pdk bundle exec rake litmus:acceptance:parallel
}

run_test() {
    local TEST="$1"

    if [ ! -f "$TEST" ]; then
        echo "Error: Test file not found: ${TEST}"
        exit 1
    fi

    if [ ! -f "$INVENTORY_FILE" ]; then
        echo "Error: Inventory file not found: ${INVENTORY_FILE}"
        exit 1
    fi

    echo "Running test: $TEST"
    HOSTS=$(yq '(.groups[] | .targets[] | .alias)' "$INVENTORY_FILE")

    for H in $HOSTS; do
        echo "Testing on host: ${H}"
        TARGET_HOST="${H}" pdk bundle exec rspec "${TEST}"
        echo "---"
    done
}

# Parse arguments
if [ -z "$1" ]; then
    echo "Error: An argument or option is required"
    echo ""
    usage
    exit 1
fi

case "$1" in
    -h|--help)
        usage
        exit 0
        ;;
    -l|--list)
        list_hosts
        exit 0
        ;;
    -a|--all)
        run_all
        exit 0
        ;;
    -*)
        echo "Error: Unknown option: $1"
        echo ""
        usage
        exit 1
        ;;
    *)
        run_test "$1"
        ;;
esac
